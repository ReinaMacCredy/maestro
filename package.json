{
  "name": "maestro-handoff",
  "version": "0.9.11",
  "type": "module",
  "bin": {
    "maestro": "./dist/maestro"
  },
  "scripts": {
    "build": "bun scripts/build.ts",
    "bump": "bun scripts/bump.ts",
    "auto-bump": "bun scripts/auto-bump.ts",
    "ci": "bun scripts/ci.ts",
    "ci:dry": "bun scripts/ci.ts --dry-run",
    "install:local": "bash ./scripts/install-local.sh ./dist/maestro",
    "release:local": "bun run build && bun run install:local",
    "deploy": "bun run bump && bun test && bun run release:local",
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cli-spinners": "^2.9.2",
    "commander": "^13.0.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@a2a-js/sdk": "0.3.13",
    "@types/express": "^5.0.3",
    "express": "^5.1.0",
    "typescript": "^5.7.0"
  }
}
